# Copy to .env and fill in real values.

# Read-only connection to the coordinator's Postgres.
DATABASE_URL=postgres://indexer_ro:pass@db.supabase.co:5432/postgres

# Walrus publisher node URL (for archiving old receipts).
WALRUS_PUBLISHER_URL=https://publisher.walrus.site

# Coordinator base URL — used to fetch the live peer registry for
# /api/nodes and /api/nodes/:peer_id status. The coordinator presents a
# self-signed (attested) cert, so set INSECURE_COORDINATOR=1.
COORDINATOR_URL=https://127.0.0.1:4000
INSECURE_COORDINATOR=1

# Optional overrides
# INDEXER_BIND=0.0.0.0:3100
# ARCHIVE_AFTER_MINUTES=5
# A node is "online" if seen within this many seconds (node re-announces
# every 30s; default 90s avoids flapping).
# NODE_ONLINE_TTL_SECS=90
