# Read-only connection to the coordinator's Postgres.
DATABASE_URL=postgres://indexer_ro:pass@db.supabase.co:5432/postgres

# Walrus publisher node URL (for archiving old receipts).
WALRUS_PUBLISHER_URL=https://publisher.walrus.site

# Optional overrides
# INDEXER_BIND=0.0.0.0:3100
# ARCHIVE_AFTER_MINUTES=5
